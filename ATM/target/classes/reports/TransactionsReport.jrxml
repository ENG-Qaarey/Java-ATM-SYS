<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="TransactionsReport" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="bb000002-0002-4002-8002-000000000001">
	<property name="ireport.zoom" value="1.0"/>
	<queryString language="SQL">
		<![CDATA[SELECT
     Transactions.`TransactionID` AS Transactions_TransactionID,
     Transactions.`AccountNumber` AS Transactions_AccountNumber,
     Transactions.`TransactionType` AS Transactions_TransactionType,
     Transactions.`Amount` AS Transactions_Amount,
     Transactions.`BalanceAfter` AS Transactions_BalanceAfter
FROM
     `Transactions` Transactions
ORDER BY Transactions.`TransactionDate` DESC]]>
	</queryString>
	<field name="Transactions_TransactionID" class="java.lang.Integer"/>
	<field name="Transactions_AccountNumber" class="java.lang.Integer"/>
	<field name="Transactions_TransactionType" class="java.lang.String"/>
	<field name="Transactions_Amount" class="java.lang.Integer"/>
	<field name="Transactions_BalanceAfter" class="java.lang.Integer"/>
	<variable name="TotalAmount" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{Transactions_Amount}]]></variableExpression>
	</variable>
	<variable name="TxCount" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{Transactions_TransactionID}]]></variableExpression>
	</variable>
