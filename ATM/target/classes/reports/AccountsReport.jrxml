	<field name="Accounts_Active" class="java.lang.String"/>
	<variable name="TotalBalance" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{Accounts_Balance}]]></variableExpression>
		<initialValueExpression><![CDATA[Integer.valueOf(0)]]></initialValueExpression>
	</variable>
	<variable name="AccountCount" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{Accounts_AccountNumber}]]></variableExpression>
		<initialValueExpression><![CDATA[Integer.valueOf(0)]]></initialValueExpression>
	</variable>
