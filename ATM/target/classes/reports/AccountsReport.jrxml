	<property name="ireport.zoom" value="1.0"/>
	<queryString language="SQL">
		<![CDATA[SELECT
     Accounts.`AccountNumber` AS Accounts_AccountNumber,
     Accounts.`FullName` AS Accounts_FullName,
     Accounts.`Occupation` AS Accounts_Occupation,
     Accounts.`Phone` AS Accounts_Phone,
     Accounts.`Balance` AS Accounts_Balance,
     CASE WHEN Accounts.`IsActive` = 1 THEN 'Active' ELSE 'Inactive' END AS Accounts_Active
FROM
     `Accounts` Accounts
ORDER BY Accounts.`AccountNumber`]]>
	</queryString>
	<field name="Accounts_AccountNumber" class="java.lang.Integer"/>
	<field name="Accounts_FullName" class="java.lang.String"/>
