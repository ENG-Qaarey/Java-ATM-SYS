<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="DepositsReport" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="cc000003-0003-4003-8003-000000000001">
	<property name="ireport.zoom" value="1.0"/>
	<queryString language="SQL">
		<![CDATA[SELECT
     Deposits.`DepositID` AS Deposits_DepositID,
     Deposits.`AccountNumber` AS Deposits_AccountNumber,
     Accounts.`FullName` AS Accounts_FullName,
     Deposits.`Amount` AS Deposits_Amount
FROM
     `Deposits` Deposits
LEFT JOIN
     `Accounts` Accounts ON Accounts.`AccountNumber` = Deposits.`AccountNumber`
ORDER BY Deposits.`DepositDate` DESC]]>
	</queryString>
	<field name="Deposits_DepositID" class="java.lang.Integer"/>
	<field name="Deposits_AccountNumber" class="java.lang.Integer"/>
	<field name="Accounts_FullName" class="java.lang.String"/>
	<field name="Deposits_Amount" class="java.lang.Integer"/>
	<variable name="TotalDeposits" class="java.lang.Integer" calculation="Sum">
		<variableExpression><![CDATA[$F{Deposits_Amount}]]></variableExpression>
	</variable>
	<variable name="DepositCount" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{Deposits_DepositID}]]></variableExpression>
	</variable>
